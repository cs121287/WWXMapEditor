<Window x:Class="WwXMapEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorldWarX Map Editor" Height="800" Width="1200">
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Map..." Click="NewMap_Click"/>
                <MenuItem Header="_Open..." Click="OpenMap_Click"/>
                <MenuItem Header="_Save" Click="SaveMap_Click"/>
                <MenuItem Header="Export as _JSON..." Click="ExportJson_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="Undo_Click"/>
                <MenuItem Header="_Redo" Click="Redo_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Click="ZoomIn_Click"/>
                <MenuItem Header="Zoom _Out" Click="ZoomOut_Click"/>
                <MenuItem Header="Reset _Zoom" Click="ZoomReset_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="New Map" Click="NewMap_Click"/>
                <Button Content="Open" Click="OpenMap_Click"/>
                <Button Content="Save" Click="SaveMap_Click"/>
                <Separator/>
                <Button Content="Undo" Click="Undo_Click"/>
                <Button Content="Redo" Click="Redo_Click"/>
                <Separator/>
                <Button Content="Zoom In" Click="ZoomIn_Click"/>
                <Button Content="Zoom Out" Click="ZoomOut_Click"/>
                <Button Content="Reset Zoom" Click="ZoomReset_Click"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content Area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- Palette Panel -->
            <StackPanel Grid.Column="0" Margin="4" Background="#EEE">
                <TextBlock Text="Palette" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>
                <TabControl>
                    <TabItem Header="Terrain">
                        <ListBox Name="TerrainPalette" Height="180"/>
                    </TabItem>
                    <TabItem Header="Properties">
                        <StackPanel>
                            <ListBox Name="PropertyPalette" Height="110"/>
                            <TextBlock Text="Property Owner" FontWeight="SemiBold" Margin="0,10,0,2"/>
                            <ComboBox Name="PropertyOwnerCombo" Width="120" Margin="0,0,0,4"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Units">
                        <ListBox Name="UnitPalette" Height="180"/>
                    </TabItem>
                </TabControl>

                <TextBlock Text="Tool:" FontWeight="SemiBold" Margin="0,16,0,2"/>
                <ComboBox Name="ToolSelector" Width="140" Margin="0,0,0,8">
                    <ComboBoxItem Content="Terrain"/>
                    <ComboBoxItem Content="Property"/>
                    <ComboBoxItem Content="Unit"/>
                </ComboBox>
            </StackPanel>

            <!-- Map Editing Canvas -->
            <Border Grid.Column="1" Margin="8" Background="DarkGray" BorderBrush="#888" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas Name="MapCanvas"
                            Background="LightGray"
                            MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                            MouseMove="MapCanvas_MouseMove"
                            MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                            Width="{Binding ActualWidth, ElementName=MapCanvas}" 
                            Height="{Binding ActualHeight, ElementName=MapCanvas}" />
                </ScrollViewer>
            </Border>

            <!-- Details Panel -->
            <StackPanel Grid.Column="2" Margin="4" Background="#F7F7F7">
                <TextBlock Text="Tile/Unit/Property Details" FontWeight="Bold" FontSize="16" Margin="0,10,0,10"/>
                <StackPanel Name="DetailsPanel"/>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Name="StatusText" Text="Ready" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Name="CoordsText" Text="(0,0)" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Name="ZoomText" Text="100%" />
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>