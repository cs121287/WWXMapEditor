<Window x:Class="WwXMapEditor.StartupMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WorldWarX Map Editor - Menu" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Content="Create New Map" Grid.Row="0" Margin="50,20,50,10" FontSize="18" Click="CreateNewMap_Click"/>
        <Button Content="Load Map" Grid.Row="1" Margin="50,10,50,10" FontSize="18" Click="LoadMap_Click"/>
        <Button Content="Exit" Grid.Row="2" Margin="50,10,50,20" FontSize="18" Click="Exit_Click"/>
    </Grid>
</Window>