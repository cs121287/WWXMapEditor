<UserControl x:Class="WwXMapEditor.Controls.SpriteSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             BorderBrush="Black" BorderThickness="2">
    <Canvas Name="SpriteCanvas" 
            Background="White"
            MouseLeftButtonDown="SpriteCanvas_MouseLeftButtonDown">
        <Rectangle Name="SelectionRectangle" 
                   Width="32" 
                   Height="32" 
                   Stroke="Red" 
                   StrokeThickness="2" 
                   Fill="Transparent"
                   Visibility="Collapsed"/>
    </Canvas>
</UserControl>